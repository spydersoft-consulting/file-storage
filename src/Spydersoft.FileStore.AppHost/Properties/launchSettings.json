{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "https://localhost:17098;http://localhost:15098",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "DOTNET_DASHBOARD_OTLP_ENDPOINT_URL": "https://localhost:21098",
        "DOTNET_RESOURCE_SERVICE_ENDPOINT_URL": "https://localhost:22098"
      }
    },
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "http://localhost:15098",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",
        "DOTNET_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:21098",
        "DOTNET_RESOURCE_SERVICE_ENDPOINT_URL": "http://localhost:22098",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true"
      }
    },
    "Testing": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:15099",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Testing",
        "DOTNET_ENVIRONMENT": "Testing",
        "DOTNET_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:21099",
        "DOTNET_RESOURCE_SERVICE_ENDPOINT_URL": "http://localhost:22099",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true"
      }
    }
  }
}
